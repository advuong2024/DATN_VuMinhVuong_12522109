generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum VaiTro {
  ADMIN
  BAC_SI
  LE_TAN
  THU_NGAN
}

enum TrangThaiTaiKhoan {
  HOAT_DONG
  KHOA
}

enum TrangThaiLichHen {
  DA_DAT
  CHO_KHAM
  DA_KHAM
  DA_HUY
}

enum TrangThaiThanhToan {
  CHUA_THANH_TOAN
  DA_THANH_TOAN
}

enum GioiTinh {
  NAM
  NU
  KHAC
}

enum PhuongThucThanhToan {
  TIEN_MAT
  CHUYEN_KHOAN
}

enum TrangThaiDichVu {
  CHO_THUC_HIEN
  DANG_THUC_HIEN
  HOAN_THANH
}

enum TrangThaiPhieuKham {
  DANG_KHAM
  HOAN_THANH
  DA_HUY
}

//////////////////////////////////////////////////////
// NHÂN VIÊN - TÀI KHOẢN
//////////////////////////////////////////////////////

model nhan_vien {
  id_nhan_vien   Int      @id @default(autoincrement())
  ten_nhan_vien  String
  ngay_sinh      DateTime?
  gioi_tinh      GioiTinh?
  so_dien_thoai  String?  @unique
  dia_chi        String?
  chuc_vu        String
  chuyen_khoa    String?
  ngay_tao       DateTime @default(now())
  ngay_cap_nhat  DateTime @updatedAt
  is_deleted     Boolean  @default(false)

  tai_khoan      tai_khoan?
  lich_hen       lich_hen[]
  phieu_kham     phieu_kham[]
  chi_tiet_dich_vu chi_tiet_dich_vu[]
}

model tai_khoan {
  id_tai_khoan   Int      @id @default(autoincrement())
  ten_dang_nhap  String   @unique
  mat_khau       String
  vai_tro        VaiTro
  trang_thai     TrangThaiTaiKhoan @default(HOAT_DONG)
  ngay_tao       DateTime @default(now())
  ngay_cap_nhat  DateTime @updatedAt
  is_deleted     Boolean  @default(false)

  id_nhan_vien   Int?     @unique
  nhan_vien      nhan_vien? @relation(fields: [id_nhan_vien], references: [id_nhan_vien])
}

//////////////////////////////////////////////////////
// BỆNH NHÂN
//////////////////////////////////////////////////////

model benh_nhan {
  id_benh_nhan  Int      @id @default(autoincrement())
  ten_benh_nhan String
  ngay_sinh     DateTime?
  gioi_tinh     GioiTinh?
  so_dien_thoai String?  @unique
  dia_chi       String?
  tien_su_benh  String?
  ngay_tao      DateTime @default(now())
  ngay_cap_nhat DateTime @updatedAt
  is_deleted    Boolean  @default(false)

  lich_hen      lich_hen[]
  phieu_kham    phieu_kham[]
}

//////////////////////////////////////////////////////
// LỊCH HẸN
//////////////////////////////////////////////////////

model lich_hen {
  id_lich_hen   Int      @id @default(autoincrement())
  thoi_gian_hen DateTime
  ly_do_kham    String?
  trang_thai    TrangThaiLichHen @default(DA_DAT)
  is_deleted    Boolean  @default(false)

  id_benh_nhan  Int
  benh_nhan     benh_nhan @relation(fields: [id_benh_nhan], references: [id_benh_nhan])

  id_nhan_vien  Int
  nhan_vien     nhan_vien @relation(fields: [id_nhan_vien], references: [id_nhan_vien])

  ngay_tao      DateTime @default(now())

  @@unique([id_nhan_vien, thoi_gian_hen])
}

//////////////////////////////////////////////////////
// PHIẾU KHÁM
//////////////////////////////////////////////////////

model phieu_kham {
  id_phieu_kham  Int      @id @default(autoincrement())
  ngay_kham      DateTime @default(now())
  trieu_chung    String?
  chan_doan      String?
  ghi_chu        String?
  trang_thai     TrangThaiPhieuKham @default(DANG_KHAM)
  is_deleted     Boolean  @default(false)

  id_benh_nhan   Int
  benh_nhan      benh_nhan @relation(fields: [id_benh_nhan], references: [id_benh_nhan])

  id_nhan_vien   Int
  nhan_vien      nhan_vien @relation(fields: [id_nhan_vien], references: [id_nhan_vien])

  don_thuoc      don_thuoc?
  thanh_toan     thanh_toan?

  chi_tiet_dich_vu chi_tiet_dich_vu[]
}

//////////////////////////////////////////////////////
// DỊCH VỤ
//////////////////////////////////////////////////////

model danh_muc_dich_vu {
  id_danh_muc   Int    @id @default(autoincrement())
  ten_danh_muc  String
  mo_ta         String?

  dich_vu       dich_vu[]
}

model dich_vu {
  id_dich_vu     Int     @id @default(autoincrement())
  ten_dich_vu    String
  gia_dich_vu    Decimal @db.Decimal(10,2)
  mo_ta          String?
  is_deleted     Boolean @default(false)

  id_danh_muc    Int
  danh_muc       danh_muc_dich_vu @relation(fields: [id_danh_muc], references: [id_danh_muc])

  chi_tiet       chi_tiet_dich_vu[]
}

model chi_tiet_dich_vu {
  id_chi_tiet     Int     @id @default(autoincrement())
  so_luong        Int     @default(1)
  gia_tai_thoi_diem Decimal @db.Decimal(10,2)
  trang_thai      TrangThaiDichVu @default(CHO_THUC_HIEN)

  id_phieu_kham   Int
  phieu_kham      phieu_kham @relation(fields: [id_phieu_kham], references: [id_phieu_kham])

  id_dich_vu      Int
  dich_vu         dich_vu @relation(fields: [id_dich_vu], references: [id_dich_vu])

  id_nhan_vien    Int?
  nhan_vien       nhan_vien? @relation(fields: [id_nhan_vien], references: [id_nhan_vien])
}

//////////////////////////////////////////////////////
// THUỐC
//////////////////////////////////////////////////////

model danh_muc_thuoc {
  id_danh_muc   Int      @id @default(autoincrement())
  ten_danh_muc  String
  mo_ta         String?

  thuoc         thuoc[]
}

model thuoc {
  id_thuoc       Int      @id @default(autoincrement())
  ten_thuoc      String
  gia_thuoc      Decimal  @db.Decimal(10,2)
  so_luong       Int
  don_vi_tinh    String?
  han_su_dung    DateTime?
  is_deleted     Boolean  @default(false)

  id_danh_muc     Int
  danh_muc_thuoc  danh_muc_thuoc @relation(fields: [id_danh_muc], references: [id_danh_muc])

  chi_tiet_don_thuoc chi_tiet_don_thuoc[]
}

//////////////////////////////////////////////////////
// ĐƠN THUỐC
//////////////////////////////////////////////////////

model don_thuoc {
  id_don_thuoc   Int      @id @default(autoincrement())
  ngay_ke_don    DateTime @default(now())
  ghi_chu        String?
  is_deleted     Boolean  @default(false)

  id_phieu_kham  Int @unique
  phieu_kham     phieu_kham @relation(fields: [id_phieu_kham], references: [id_phieu_kham])

  chi_tiet       chi_tiet_don_thuoc[]
}

model chi_tiet_don_thuoc {
  id_chi_tiet    Int      @id @default(autoincrement())
  so_luong       Int
  lieu_dung      String?
  gia_tai_thoi_diem Decimal @db.Decimal(10,2)

  id_don_thuoc   Int
  don_thuoc      don_thuoc @relation(fields: [id_don_thuoc], references: [id_don_thuoc])

  id_thuoc       Int
  thuoc          thuoc @relation(fields: [id_thuoc], references: [id_thuoc])
}

//////////////////////////////////////////////////////
// THANH TOÁN
//////////////////////////////////////////////////////

model thanh_toan {
  id_thanh_toan   Int      @id @default(autoincrement())
  tong_tien       Decimal  @db.Decimal(10,2)
  phuong_thuc     PhuongThucThanhToan?
  trang_thai      TrangThaiThanhToan @default(CHUA_THANH_TOAN)
  ngay_thanh_toan DateTime?
  is_deleted      Boolean  @default(false)

  id_phieu_kham   Int @unique
  phieu_kham      phieu_kham @relation(fields: [id_phieu_kham], references: [id_phieu_kham])
}